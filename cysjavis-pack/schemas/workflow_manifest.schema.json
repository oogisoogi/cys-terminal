{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cysjavis/schemas/workflow_manifest.schema.json",
  "title": "CYSJavis Typed Workflow Manifest (OpenMontage D4)",
  "description": "산문 워크플로우를 타입드 계약으로. success_criteria는 콘텐츠 속성(checks)만 — file_exists 없음(producer≠evaluator). 점수·비용 키 금지. 검증의 진실은 javis_manifest.py(hand-roll·stdlib); 이 스키마는 계약 문서다.",
  "type": "object",
  "additionalProperties": false,
  "required": ["name", "phases"],
  "properties": {
    "name": {"type": "string", "minLength": 1},
    "version": {"type": "string"},
    "description": {"type": "string"},
    "phases": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/phase"}
    }
  },
  "$defs": {
    "phase": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "skill", "success_criteria"],
      "properties": {
        "id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$"},
        "skill": {"type": "string", "minLength": 1},
        "requires": {"type": "array", "items": {"type": "string"}},
        "produces": {"type": "array", "items": {"type": "string"}},
        "success_criteria": {"$ref": "#/$defs/success_criteria"},
        "review_focus": {"type": "array", "items": {"type": "string"}},
        "human_approval_default": {"type": "boolean"},
        "max_revisions": {"type": "integer", "minimum": 1, "maximum": 10},
        "budget_minutes": {"type": "integer", "minimum": 1}
      }
    },
    "success_criteria": {
      "type": "object",
      "additionalProperties": false,
      "required": ["statement", "checks"],
      "properties": {
        "statement": {"type": "string", "minLength": 1},
        "checks": {
          "type": "array",
          "minItems": 1,
          "items": {"$ref": "#/$defs/check"}
        }
      }
    },
    "check": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind"],
      "properties": {
        "kind": {
          "type": "string",
          "enum": ["citation_present", "contradiction_flagged", "min_sources",
                   "section_present", "no_unsupported_claims", "json_valid",
                   "field_present", "min_items"]
        },
        "value": {},
        "statement": {"type": "string"}
      },
      "allOf": [
        {
          "if": {"required": ["kind"], "properties": {"kind": {"const": "min_sources"}}},
          "then": {"required": ["value"], "properties": {"value": {"type": "integer", "minimum": 1}}}
        },
        {
          "if": {"required": ["kind"], "properties": {"kind": {"const": "section_present"}}},
          "then": {"required": ["value"], "properties": {"value": {"type": "string", "minLength": 1}}}
        },
        {
          "if": {"required": ["kind"], "properties": {"kind": {"const": "field_present"}}},
          "then": {"required": ["value"], "properties": {"value": {"type": "string", "minLength": 1}}}
        },
        {
          "if": {"required": ["kind"], "properties": {"kind": {"const": "min_items"}}},
          "then": {"required": ["value"], "properties": {"value": {
            "type": "object", "additionalProperties": false,
            "required": ["field", "min"],
            "properties": {"field": {"type": "string", "minLength": 1},
                           "min": {"type": "integer", "minimum": 1}}}}}
        }
      ],
      "comment": "kind에 file_exists 없음 — 산출물 존재가 아니라 내용을 강제(producer≠evaluator). value 정수·필수 제약은 javis_manifest.py(권위)와 위 if/then이 함께 강제."
    }
  }
}
