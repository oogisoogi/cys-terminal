{
  "name": "clip-factory",
  "version": "1.0",
  "description": "롱폼 소스 1개(웨비나·스트림·인터뷰)에서 플랫폼별 최적화된 N개 독립 숏클립을 추출하는 배치-N 파이프라인. transcription→세그먼트 랭킹→플랫폼별 프레이밍→배치 합성. provider는 javis_select 위임, 모든 계획 클립에 자산·편집·출력이 존재해야 한다.",
  "phases": [
    {
      "id": "idea",
      "skill": "youtube-video-pipeline",
      "produces": ["brief.md"],
      "success_criteria": {
        "statement": "추출할 클립 수(N)와 플랫폼 믹스 타깃을 정의한다(범위·클립수·플랫폼 섹션 포함).",
        "checks": [
          {"kind": "section_present", "value": "클립", "statement": "클립 수 섹션 존재"},
          {"kind": "section_present", "value": "플랫폼", "statement": "플랫폼 섹션 존재"}
        ]
      },
      "review_focus": ["clip-count-target", "platform-mix"],
      "human_approval_default": true,
      "max_revisions": 3,
      "budget_minutes": 15
    },
    {
      "id": "script",
      "skill": "transcription",
      "produces": ["transcript.json"],
      "success_criteria": {
        "statement": "javis_select로 전사 provider 선택 후 정확한 타임스탬프 전사를 산출한다(세그먼트 경계 추출의 토대).",
        "checks": [
          {"kind": "json_valid", "statement": "transcript.json 파싱"},
          {"kind": "field_present", "value": "segments", "statement": "전사 세그먼트 필드 존재"},
          {"kind": "min_items", "value": {"field": "segments", "min": 1}, "statement": "세그먼트 ≥1(빈 전사 차단)"}
        ]
      },
      "review_focus": ["timestamp-accuracy"],
      "human_approval_default": false,
      "max_revisions": 3,
      "budget_minutes": 20
    },
    {
      "id": "scene-plan",
      "skill": "video-stitch",
      "produces": ["scene_plan.json"],
      "success_criteria": {
        "statement": "자기완결 클립 N개를 식별하고(깔끔한 in/out 경계) 플랫폼별 프레이밍/종횡비를 계획한다. 후보 클립 수 ≥ 브리프 타깃 N.",
        "checks": [
          {"kind": "json_valid", "statement": "scene_plan.json 파싱(clips 배열 포함)"},
          {"kind": "field_present", "value": "clips", "statement": "후보 클립 배열 존재"},
          {"kind": "min_items", "value": {"field": "clips", "min": 2}, "statement": "후보 클립 ≥2(배치-N floor·정확한 N은 리뷰)"}
        ]
      },
      "review_focus": ["clean-boundaries", "self-contained-clips", "count>=N"],
      "human_approval_default": false,
      "max_revisions": 3,
      "budget_minutes": 20
    },
    {
      "id": "assets",
      "skill": "video-stitch-captions",
      "produces": ["asset_manifest.json"],
      "success_criteria": {
        "statement": "클립별 자막(시간 오프셋)·오디오 정규화·공유 훅/타이틀/브랜딩 자산을 준비한다. 모든 계획 클립에 자산 존재.",
        "checks": [
          {"kind": "json_valid", "statement": "asset_manifest.json 파싱"}
        ]
      },
      "review_focus": ["per-clip-captions", "consistent-branding"],
      "human_approval_default": false,
      "max_revisions": 3,
      "budget_minutes": 25
    },
    {
      "id": "edit",
      "skill": "video-stitch",
      "produces": ["edit_decisions.json"],
      "success_criteria": {
        "statement": "클립별 훅 배치(첫 2-3초)·일관 자막 스타일·트림 결정을 산출한다. 모든 계획 클립에 편집 결정 존재.",
        "checks": [
          {"kind": "json_valid", "statement": "edit_decisions.json 파싱"}
        ]
      },
      "review_focus": ["hook-first", "consistent-styling", "every-clip-covered"],
      "human_approval_default": false,
      "max_revisions": 3,
      "budget_minutes": 20
    },
    {
      "id": "compose",
      "skill": "video-verify",
      "produces": ["render_report.json"],
      "success_criteria": {
        "statement": "배치 합성·일관 레벨 오디오믹스 후 render_report를 산출한다. 모든 N개 클립 출력이 존재하고 ffprobe 통과하며 각자 플랫폼 스펙을 충족한다(render_runtime 무음 swap=위반).",
        "checks": [
          {"kind": "json_valid", "statement": "render_report.json 파싱(클립별 결과 포함)"},
          {"kind": "field_present", "value": "render_runtime", "statement": "사용 런타임 기록(무음 swap 검출·SF-RENDER-RUNTIME-SWAP)"},
          {"kind": "min_items", "value": {"field": "results", "min": 2}, "statement": "클립별 결과 ≥2(전 클립 렌더 floor)"}
        ]
      },
      "review_focus": ["all-N-clips-rendered", "per-platform-specs", "consistent-levels"],
      "human_approval_default": true,
      "max_revisions": 5,
      "budget_minutes": 35
    },
    {
      "id": "publish",
      "skill": "youtube-video-pipeline",
      "produces": ["publish_log.json"],
      "success_criteria": {
        "statement": "플랫폼별 메타데이터로 클립별 익스포트를 산출한다.",
        "checks": [
          {"kind": "json_valid", "statement": "publish_log.json 파싱"}
        ]
      },
      "review_focus": ["per-platform-metadata"],
      "human_approval_default": false,
      "max_revisions": 2,
      "budget_minutes": 10
    }
  ]
}
