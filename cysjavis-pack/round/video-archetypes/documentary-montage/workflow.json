{
  "name": "documentary-montage",
  "version": "1.0",
  "description": "검색-우선 테마 몽타주: 스톡/아카이브 클립 검색→씬 몽타주 계획→자산(stock-retrieval·music·color-grade)→스티치 편집→합성으로 다큐멘터리식 영상을 만든다. provider는 하드코딩 없이 javis_select 위임(무료·로컬 바닥부터), render_runtime은 edit에 고정되고 무음 swap은 CRITICAL 위반(SF-RENDER-RUNTIME-SWAP).",
  "phases": [
    {
      "id": "idea",
      "skill": "youtube-video-pipeline",
      "produces": ["brief.md"],
      "success_criteria": {
        "statement": "테마·내러티브 아크·타깃 길이를 반영한 몽타주 브리프를 작성한다(범위·테마 섹션 포함).",
        "checks": [
          {"kind": "section_present", "value": "범위", "statement": "범위 섹션 존재"},
          {"kind": "section_present", "value": "테마", "statement": "테마 섹션 존재"}
        ]
      },
      "review_focus": ["theme-clarity", "narrative-arc"],
      "human_approval_default": true,
      "max_revisions": 3,
      "budget_minutes": 15
    },
    {
      "id": "scene-plan",
      "skill": "video-stitch",
      "produces": ["scene_plan.json"],
      "success_criteria": {
        "statement": "테마별 스톡/아카이브 클립 검색 쿼리와 몽타주 씬 시퀀스를 계획한다(scenes 각각에 검색 쿼리·길이·내러티브 위치).",
        "checks": [
          {"kind": "json_valid", "statement": "scene_plan.json 파싱"},
          {"kind": "field_present", "value": "scenes", "statement": "몽타주 씬 시퀀스 필드 존재"},
          {"kind": "min_items", "value": {"field": "scenes", "min": 2}, "statement": "씬 ≥2(몽타주 커버리지·단일클립 차단)"}
        ]
      },
      "review_focus": ["search-query-quality", "montage-flow", "archive-relevance"],
      "human_approval_default": false,
      "max_revisions": 3,
      "budget_minutes": 20
    },
    {
      "id": "assets",
      "skill": "media-gen",
      "produces": ["asset_manifest.json"],
      "success_criteria": {
        "statement": "stock-retrieval로 계획 씬별 스톡/아카이브 클립을 검색·확보하고 music(배경음악)·color-grade 룩·end-tag 자산을 준비한다. 생성/검색 provider는 javis_select 위임. 모든 계획 씬에 후보 클립 존재.",
        "checks": [
          {"kind": "json_valid", "statement": "asset_manifest.json 파싱"},
          {"kind": "field_present", "value": "clips", "statement": "확보 클립 자산 배열 존재"},
          {"kind": "min_items", "value": {"field": "clips", "min": 2}, "statement": "확보 클립 ≥2(씬별 자산 floor)"}
        ]
      },
      "review_focus": ["stock-license-clear", "music-mood-fit", "color-grade-consistency"],
      "human_approval_default": false,
      "max_revisions": 3,
      "budget_minutes": 30
    },
    {
      "id": "edit",
      "skill": "video-stitch",
      "produces": ["edit_decisions.json"],
      "success_criteria": {
        "statement": "클립 스티치 순서·트랜지션·color-grade 적용·뮤직 베드 동기·end-tag 배치 편집 결정을 산출한다. render_runtime을 명시 고정(무음 swap=위반·SF-RENDER-RUNTIME-SWAP).",
        "checks": [
          {"kind": "json_valid", "statement": "edit_decisions.json 파싱"},
          {"kind": "field_present", "value": "render_runtime", "statement": "render_runtime 명시 고정(무음 swap 방지·SF-RENDER-RUNTIME-SWAP)"}
        ]
      },
      "review_focus": ["stitch-pacing", "music-sync", "render-runtime-locked"],
      "human_approval_default": false,
      "max_revisions": 3,
      "budget_minutes": 20
    },
    {
      "id": "compose",
      "skill": "video-verify",
      "produces": ["render_report.json"],
      "success_criteria": {
        "statement": "합성·오디오믹스 후 render_report를 산출한다. render_runtime은 edit_decisions의 고정값과 일치해야 하며(무음 swap=CRITICAL 위반) ffprobe·시각 QA 통과를 기록한다.",
        "checks": [
          {"kind": "json_valid", "statement": "render_report.json 파싱"},
          {"kind": "field_present", "value": "render_runtime", "statement": "render_report에 사용 런타임 기록(edit 고정값 대조·무음 swap 검출·SF-RENDER-RUNTIME-SWAP)"}
        ]
      },
      "review_focus": ["render-runtime-match", "playable", "visual-qa-pass"],
      "human_approval_default": true,
      "max_revisions": 5,
      "budget_minutes": 30
    }
  ]
}
